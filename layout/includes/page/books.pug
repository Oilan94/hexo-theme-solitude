- const books = site.data.books
- const pageSize = books.page_size || 10
- const totalPages = Math.max(1, Math.ceil(books.data_list.items.length / pageSize))

include ../widgets/page/banner

if books && books.data_list && books.data_list.items
  #ibook
    each item, itemIndex in books.data_list.items.slice(0, pageSize)
      .ibook-item
        .ibook-picture
          img(src=item.image, data-lazy-src=item.image, loading="lazy", alt=item.title)
        .ibook-info
          div
            a(href=item.alt, target="_blank")= item.title
          .ibook-meta= item.meta
          .ibook-rating= item.mark
          .ibook-comment= item.comment

    if books.data_list.items.length > pageSize
      .ibook-pagination
        a.ibook-button(href="#", onclick='showPage(1); return false;') 首页
        a.ibook-button(href="#", onclick='showPage(Math.max(getCurrentPage() - 1, 1)); return false;') 上一页
        span.ibook-page-num(id="page-num") 1 / #{totalPages}
        a.ibook-button(href="#", onclick='showPage(Math.min(getCurrentPage() + 1, ' + totalPages + ')); return false;') 下一页
        a.ibook-button(href="#", onclick='showPage(' + totalPages + '); return false;') 末页

    script.
      function getCurrentPage() {
        const pageNum = document.getElementById('page-num')?.textContent.split('/')[0].trim();
        return pageNum ? parseInt(pageNum, 10) : 1;
      }

      function showPage(page) {
        const pageSize = !{pageSize};
        const allItems = !{JSON.stringify(books.data_list.items || [])};
        const totalPages = Math.max(1, Math.ceil(allItems.length / pageSize));
        const start = (page - 1) * pageSize;
        const end = Math.min(start + pageSize, allItems.length);

        const container = document.getElementById('ibook');
        const pagination = document.querySelector('.ibook-pagination');

        if (container) {
          const items = container.getElementsByClassName('ibook-item');
          for (let i = items.length - 1; i >= 0; i--) {
            items[i].remove();
          }

          allItems.slice(start, end).forEach(item => {
            const div = document.createElement('div');
            div.className = 'ibook-item';
            div.innerHTML = `
              <div class="ibook-picture">
                <img src="${item.image}" data-lazy-src="${item.image}" loading="lazy" alt="${item.title}">
              </div>
              <div class="ibook-info">
                <div><a href="${item.alt}" target="_blank">${item.title}</a></div>
                <div class="ibook-meta">${item.meta}</div>
                <div class="ibook-rating">${item.mark}</div>
                <div class="ibook-comment">${item.comment}</div>
              </div>
            `;
            container.insertBefore(div, pagination);
          });
        }

        const pageNumElement = document.getElementById('page-num');
        if (pageNumElement) {
          pageNumElement.textContent = `${page} / ${totalPages}`;
        }

        // ✅ 重新初始化懒加载和灯箱
        if (typeof window.refreshFn === 'function') {
          window.refreshFn();
        }
      }

      document.addEventListener('DOMContentLoaded', () => showPage(1));
else
  p No data available.