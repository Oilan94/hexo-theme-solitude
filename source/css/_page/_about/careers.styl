#about-page
  .author-content-item.careers
    min-height 400px

    img
      position absolute
      left 0
      bottom 0
      height: 100%
      transition .6s
      user-select none
      z-index: -1
      object-fit: cover

    .careers-group
      margin-top 12px

    .careers-item
      display flex
      align-items center

      .circle
        width 16px
        height 16px
        margin-right 8px
        border-radius 16px

      .name
        color var(--efu-secondtext)
        text-shadow  0.5px 0.5px 1px rgba(0, 0, 0, 0.5)